#%Module -*- tcl -*-
##
## modulefile
##
proc ModulesHelp { } {

  puts stderr "\tAdds fsl to your environment variables,"
}

module-whatis "adds fsl to your environment variables"

set            root                 /home/inb/soporte/lanirem_software/fsl_6.0.7.22

prepend-path	FSLDIR		        $root
prepend-path	PATH		        $root/share/fsl/bin
#append-path	LD_LIBRARY_PATH	    $root/lib


# variables from $root/etc/fslconf/fsl.sh
setenv	        FSLOUTPUTTYPE       NIFTI_GZ
setenv	        FSLMULTIFILEQUIT    TRUE
prepend-path	FSLTCLSH	        $root/bin/fsltclsh
prepend-path	FSLWISH		        $root/bin/fslwish
setenv	        FSLPARALLEL	        1
unsetenv        GTK_IM_MODULE


# configure fsl_sub
setenv	        FSLSUB_CONF		    $root/etc/fslconf/fsl_sub.yml
setenv	        FSLGECUDAQ	        nvidia.q
setenv          FSLSUB_QUEUE        all.q

conflict fsl
